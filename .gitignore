# ====================================
# ORBITUNE - Comprehensive .gitignore
# ====================================

# ==================
# Python
# ==================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# PyTorch models and weights
*.pth
*.pt
*.ckpt
*.model
*.weights

# Jupyter Notebook
.ipynb_checkpoints
# Keep .ipynb notebooks for documentation

# IPython
profile_default/
ipython_config.py

# ==================
# Node.js / React / Next.js
# ==================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Next.js build output
.next/
out/
.vercel

# Production build
build/
dist/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Package manager lock files (optional - uncomment if needed)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# TypeScript cache
*.tsbuildinfo
next-env.d.ts

# ==================
# Audio & Media Files
# ==================
# Ignore ALL STORAGE audio/media files (keep only .gitkeep)
STORAGE/raw_audio/**
!STORAGE/raw_audio/.gitkeep

STORAGE/processed/**
!STORAGE/processed/.gitkeep

STORAGE/spatial/**
!STORAGE/spatial/.gitkeep

STORAGE/cache/**
!STORAGE/cache/.gitkeep

STORAGE/thumbnails/**
!STORAGE/thumbnails/.gitkeep

# Ignore audio files anywhere
STORAGE/**/*.wav
STORAGE/**/*.mp3
STORAGE/**/*.flac
STORAGE/**/*.m4a
STORAGE/**/*.ogg
STORAGE/**/*.aac
STORAGE/**/*.mhtml
STORAGE/**/*.json

# Model checkpoints
checkpoints/
*.h5
# ==================
# IDE & Editors
# ==================
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ==================
# OS Files
# ==================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*

# ==================
# Logs & Temporary Files
# ==================
*.log
logs/
*.tmp
*.temp
*.bak
*.swp
*.swo

# Python logs
pip-log.txt
pip-delete-this-directory.txt

# ==================
# API Keys & Secrets
# ==================
.env
.env.local
.env.*.local
secrets.json
config/secrets.py
*.key
*.pem
*.cert

# Google API credentials
credentials.json
token.json
client_secret*.json

# ==================
# Testing
# ==================
.pytest_cache/
.coverage
htmlcov/
test-results/
*.test.js.snap

# ==================
# Documentation (Optional)
# ==================
# Uncomment if you don't want to track these
# *.md
# docs/_build/

# ==================
# Miscellaneous
# ==================
*.zip
*.tar.gz
*.rar
*.7z

# Backup files
*.backup
*.old

# Database files
*.db
*.sqlite
*.sqlite3

# Compiled files
*.com
*.class
*.dll
*.exe
*.o
*.so

# Large binary files
*.bin
*.dat

# ==================
# Project Specific
# ==================
# Keep all backend and AI-ML source code
# Only ignore large temporary/output files

# Temporary processing files
processing_temp/
temp/
tmp/
